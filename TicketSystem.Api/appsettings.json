{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\sqlexpress;Database=TicketSystemDb;Trusted_Connection=True;TrustServerCertificate=True",
    "Redis": "localhost:6379,password=,defaultDatabase=0,connectTimeout=5000,abortConnect=false",
    "RabbitMQ": "amqp://guest:guest@localhost:5672/"
  },
  "RabbitMQ": {
    "Enabled": true,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "RetryCount": 3,
    "RetryDelayMs": 1000,
    "PaymentRetryMaxAttempts": 3
  },
  "Redis": {
    "Enabled": true,
    "LockTimeoutSeconds": 10,
    "LockRetryCount": 5,
    "LockRetryBackoffMs": 100,
    "ConnectionString": "localhost:6379,password=,defaultDatabase=0,connectTimeout=5000,abortConnect=false",
    "CacheExpiration": {
      "TripsList": 300,
      "TripDetails": 600,
      "AvailableSeats": 60,
      "Reservation": 900
    }
  },
  "Payment": {
    "SuccessRate": 0.8,
    "DelayMs": 1000
  },
  "Workers": {
    "ReservationExpirationEnabled": true,
    "ReservationExpirationIntervalMinutes": 1
  },
  "Email": {
    "Enabled": true,
    "Smtp": {
      "Host": "localhost",
      "Port": 25,
      "EnableSsl": false,
      "Username": "",
      "Password": "",
      "From": "ticketsystem@localhost",
      "FromName": "Ticket System"
    }
  },
  "AllowedHosts": "*"
}